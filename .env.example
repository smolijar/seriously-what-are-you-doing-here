# Slack credentials from your authenticated web session.
SLACK_TOKEN=xoxc-...
SLACK_COOKIE=xoxd-...

# Target person.
SLACK_USER_HANDLE=example-handle
SLACK_USER_ID=U0123456789
GITHUB_USER_HANDLE=example-github-user

# CSV list of GitHub repositories.
REPOS=owner/repo-one,owner/repo-two

# Inclusive start date and exclusive end date, both in UTC calendar days.
TIME_FROM=2026-01-01
TIME_TO=2026-04-01

# Where monthly outputs are written.
OUTPUT_DIR=out
